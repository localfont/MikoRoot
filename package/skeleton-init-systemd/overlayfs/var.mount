[Unit]
Description=Variable storage overlay
Documentation=man:file-hierarchy(7)
ConditionPathIsSymbolicLink=!/var
DefaultDependencies=no
After=prepare-var-overlay.service
BindsTo=prepare-var-overlay.service

[Mount]
What=overlay_var
Where=/var
Type=overlay
Options=lowerdir=/run/mikoos/mounts/var/lower,upperdir=/run/mikoos/mounts/var/upper,workdir=/run/mikoos/mounts/var/work,redirect_dir=on,index=on,xino=on
LazyUnmount=true
